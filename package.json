{
  "name": "zophiel",
  "version": "0.1.0",
  "private": true,
  "description": "Chronic pain tracker — monorepo",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:server": "pnpm --filter @zophiel/server run dev",
    "dev:client": "pnpm --filter @zophiel/client run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
